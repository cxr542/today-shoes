# Google AI Studio API 키 — https://aistudio.google.com/apikey
# 사진에서 러닝화 이름·특징·추천 용도 자동 분석 (Gemini)
EXPO_PUBLIC_GOOGLE_AI_API_KEY=your-google-ai-studio-key

# 선택: 모델 지정 (미설정 시 2.5-flash → lite → 1.5-flash 순으로 시도)
# EXPO_PUBLIC_GEMINI_MODEL=gemini-2.5-flash

# 폴더(assets/seed) 이미지를 앱 시작 시 자동 등록 — 기본 끔. 켜려면 true
# EXPO_PUBLIC_AUTO_IMPORT_SEEDS=false
